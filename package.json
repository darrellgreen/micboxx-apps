{
  "name": "micboxx-apps",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:consumer": "npm run start --workspace=@micboxx/consumer",
    "dev:creator": "npm run start --workspace=@micboxx/creator",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
