{
  "name": "@micboxx/creator",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "prestart": "node scripts/ensure-node.mjs",
    "preandroid": "node scripts/ensure-node.mjs",
    "preios": "node scripts/ensure-node.mjs",
    "preweb": "node scripts/ensure-node.mjs",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:fixtures": "EXPO_PUBLIC_FORCE_FIXTURES=1 expo start --web --localhost",
    "verify:web": "EXPO_PUBLIC_FORCE_FIXTURES=1 expo start --web --localhost --port 3016",
    "verify:web:creator-ready": "EXPO_PUBLIC_FORCE_FIXTURES=1 EXPO_PUBLIC_CREATOR_FIXTURE_SCENARIO=creator_ready expo start --web --localhost --port 3016",
    "verify:web:needs-profile": "EXPO_PUBLIC_FORCE_FIXTURES=1 EXPO_PUBLIC_CREATOR_FIXTURE_SCENARIO=needs_profile expo start --web --localhost --port 3016",
    "verify:web:needs-album": "EXPO_PUBLIC_FORCE_FIXTURES=1 EXPO_PUBLIC_CREATOR_FIXTURE_SCENARIO=needs_album expo start --web --localhost --port 3016",
    "verify:web:needs-track": "EXPO_PUBLIC_FORCE_FIXTURES=1 EXPO_PUBLIC_CREATOR_FIXTURE_SCENARIO=needs_track expo start --web --localhost --port 3016",
    "verify:web:non-creator": "EXPO_PUBLIC_FORCE_FIXTURES=1 EXPO_PUBLIC_CREATOR_FIXTURE_SCENARIO=non_creator expo start --web --localhost --port 3016",
    "verify:web:failed-processing": "EXPO_PUBLIC_FORCE_FIXTURES=1 EXPO_PUBLIC_CREATOR_FIXTURE_SCENARIO=failed_processing expo start --web --localhost --port 3016",
    "test:bootstrap-routes": "npx --yes tsx scripts/test-bootstrap-routes.ts",
    "test:revenue-visibility": "npx --yes tsx scripts/test-revenue-visibility.ts",
    "test:audience-growth": "npx --yes tsx scripts/test-audience-growth.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@expo/vector-icons": "^15.0.3",
    "@livekit/react-native": "^2.11.0",
