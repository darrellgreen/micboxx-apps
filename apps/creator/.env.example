# MicBoxx mobile environment
#
# Copy to `.env` or `.env.local` and fill in values. Any var prefixed with
# `EXPO_PUBLIC_` is inlined into the app bundle at build time and is NOT a
# secret — do not put anything secret here. (There are no real secrets the
# mobile app needs: Drupal auth uses OAuth2 + PKCE so the public client
# has no secret, and Firebase social auth goes through the web bridge so
# the Firebase Admin private key never touches the mobile bundle.)

# Drupal backend (source of truth for /v1/*).
EXPO_PUBLIC_DRUPAL_BASE_URL=https://api.micboxx.com

# OAuth2 client registered in Drupal `simple_oauth`. See
# docs/micboxx-mobile-api-contract-map.md §15 item 4 for the consumer
# config that needs to be created server-side. Public client, PKCE-only,
# no client secret.
EXPO_PUBLIC_DRUPAL_OAUTH_CLIENT_ID=micboxx-mobile
EXPO_PUBLIC_DRUPAL_OAUTH_SCOPE=micboxx:dashboard

# OAuth redirect URI registered on the Drupal consumer.
#
# Installed MicBoxx builds use the direct custom-scheme redirect below.
# Expo Go uses the registered HTTPS relay /v1/auth/mobile-callback instead.
# The server bridge reads the app callback URI from OAuth state and then
# returns the browser session to the running Expo app.
#
# Register this exact value in Drupal:
#   Admin → Configuration → Web services → Simple OAuth → Consumers
#   Redirect URI: micboxx://auth/callback
EXPO_PUBLIC_DRUPAL_OAUTH_REDIRECT_URI=micboxx://auth/callback

# Next.js web app. Only used for one endpoint:
# `POST /api/social/auth/token` — the Firebase custom token bridge that
# lets mobile sign into the shared Firestore social layer without
# shipping the Firebase Admin key.
EXPO_PUBLIC_MICBOXX_WEB_BASE_URL=https://www.micboxx.com

# Firebase client config for the shared Firestore social layer. These are
# public client identifiers; Firebase Admin credentials stay in micboxx-web.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Expo deep-link scheme used as the OAuth redirect URI base. Must match
# `scheme` in app.json for native dev/prod builds.
EXPO_PUBLIC_APP_SCHEME=micboxx
